generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // BugTracker Relations
  reportedIssues Issue[]        @relation("Reporter")
  assignedIssues Issue[]        @relation("Assignee")
  notes          Note[]
  notifications  Notification[] @relation("NotificationRecipient")
  notificationsCreated Notification[] @relation("NotificationActor")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// BugTracker Models

model Issue {
  id          String  @id @default(cuid())
  publicKey   String? @unique
  title       String
  description String?
  status      String  @default("OPEN") // OPEN, IN_PROGRESS, REVIEW, DONE
  priority    String  @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  severity    String  @default("MINOR") // MINOR, MAJOR, CRITICAL, BLOCKER
  type        String  @default("BUG") // BUG, FEATURE, TASK
  tags        String?
  environment String?

  // FiveM-specific
  resourceName      String? // e.g. es_extended, my-job, police-mdt
  serverVersion     String? // e.g. 6683, artifact
  reproductionSteps String? // Steps to reproduce (bugs)
  expectedBehavior  String? // What should happen (bugs/features)

  // Jira/Trello/Asana-style
  dueDate          DateTime?
  storyPoints      Int? // 1,2,3,5,8 for estimation
  label            String? // Optional single label/category; tags for multi
  discordChannelId String?
  discordThreadId  String?   @unique
  discordMessageId String?

  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  assigneeId String?
  assignee   User?    @relation("Assignee", fields: [assigneeId], references: [id])
  notes      Note[]

  // Subtasks (parent/child relationship)
  parentIssueId String?
  parentIssue   Issue?  @relation("IssueSubtasks", fields: [parentIssueId], references: [id], onDelete: SetNull)
  subtasks      Issue[] @relation("IssueSubtasks")

  // Linked issues (blocks / blocked by / relates to / duplicates)
  outgoingLinks IssueLink[] @relation("IssueLinkSource")
  incomingLinks IssueLink[] @relation("IssueLinkTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentIssueId])
}

model IssueLink {
  id        String   @id @default(cuid())
  // BLOCKS, BLOCKED_BY, RELATES_TO, DUPLICATES
  type      String
  sourceId  String
  targetId  String
  source    Issue    @relation("IssueLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Issue    @relation("IssueLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
}

model Notification {
  id        String    @id @default(cuid())
  // MENTION, ASSIGNED, STATUS_CHANGE, COMMENT, LINKED, SUBTASK
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  issueId String?

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Note {
  id               String  @id @default(cuid())
  title            String?
  content          String
  isThread         Boolean @default(false)
  category         String?
  parentId         String?
  source           String  @default("APP") // APP, DISCORD
  discordMessageId String? @unique
  discordAuthorId  String?
  discordAuthorTag String?
  authorId         String
  author           User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent           Note?   @relation("NoteReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Note[]  @relation("NoteReplies")
  issueId          String?
  issue            Issue?  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id        String   @id @default(cuid())
  discordId String   @unique
  role      String   @default("Member")
  createdAt DateTime @default(now())
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
