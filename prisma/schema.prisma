generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // BugTracker Relations
  reportedIssues Issue[]        @relation("Reporter")
  assignedIssues Issue[]        @relation("Assignee")
  notes          Note[]
  notifications  Notification[] @relation("NotificationRecipient")
  notificationsCreated Notification[] @relation("NotificationActor")
  issueActivities IssueActivity[] @relation("ActivityActor")
  savedViews     SavedView[]
  announcements  Announcement[] @relation("AnnouncementAuthor")
  incidents      Incident[]     @relation("IncidentReporter")
  assignedIncidents Incident[]  @relation("IncidentAssignee")
  releases       Release[]      @relation("ReleaseAuthor")
  playerReports  PlayerReport[] @relation("ReportReporter")
  assignedReports PlayerReport[] @relation("ReportAssignee")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// BugTracker Models

model Issue {
  id          String  @id @default(cuid())
  publicKey   String? @unique
  title       String
  description String?
  status      String  @default("OPEN") // BACKLOG, OPEN, IN_PROGRESS, REVIEW, DONE
  priority    String  @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  severity    String  @default("MINOR") // MINOR, MAJOR, CRITICAL, BLOCKER
  type        String  @default("BUG") // BUG, FEATURE, TASK
  tags        String?
  environment String?

  // FiveM-specific
  resourceName      String? // e.g. es_extended, my-job, police-mdt
  serverVersion     String? // e.g. 6683, artifact
  reproductionSteps String? // Steps to reproduce (bugs)
  expectedBehavior  String? // What should happen (bugs/features)

  // Jira/Trello/Asana-style
  dueDate          DateTime?
  storyPoints      Int? // 1,2,3,5,8 for estimation
  label            String? // Optional single label/category; tags for multi
  discordChannelId String?
  discordThreadId  String?   @unique
  discordMessageId String?

  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  assigneeId String?
  assignee   User?    @relation("Assignee", fields: [assigneeId], references: [id])
  notes      Note[]
  activities IssueActivity[]
  releaseIssues ReleaseIssue[]
  incidentLinks IncidentIssue[]
  reportLinks PlayerReportIssue[]

  // Subtasks (parent/child relationship)
  parentIssueId String?
  parentIssue   Issue?  @relation("IssueSubtasks", fields: [parentIssueId], references: [id], onDelete: SetNull)
  subtasks      Issue[] @relation("IssueSubtasks")

  // Linked issues (blocks / blocked by / relates to / duplicates)
  outgoingLinks IssueLink[] @relation("IssueLinkSource")
  incomingLinks IssueLink[] @relation("IssueLinkTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentIssueId])
}

model IssueLink {
  id        String   @id @default(cuid())
  // BLOCKS, BLOCKED_BY, RELATES_TO, DUPLICATES
  type      String
  sourceId  String
  targetId  String
  source    Issue    @relation("IssueLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Issue    @relation("IssueLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
}

model Notification {
  id        String    @id @default(cuid())
  // MENTION, ASSIGNED, STATUS_CHANGE, COMMENT, LINKED, SUBTASK
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  issueId String?

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Note {
  id               String  @id @default(cuid())
  title            String?
  content          String
  isThread         Boolean @default(false)
  category         String?
  parentId         String?
  source           String  @default("APP") // APP, DISCORD
  discordMessageId String? @unique
  discordAuthorId  String?
  discordAuthorTag String?
  authorId         String
  author           User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent           Note?   @relation("NoteReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Note[]  @relation("NoteReplies")
  issueId          String?
  issue            Issue?  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id                       String     @id @default(cuid())
  discordId                String     @unique
  role                     String     @default("Member")
  staffRoleId              String?
  staffPermissionOverrides Json?
  createdAt                DateTime   @default(now())

  staffRole StaffRole? @relation(fields: [staffRoleId], references: [id], onDelete: SetNull)

  @@index([staffRoleId])
}

model StaffRole {
  id          String   @id @default(cuid())
  name        String   @unique
  baseRole    String   @default("Member")
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members ProjectMember[]
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model IssueActivity {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([issueId, createdAt])
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  pinned      Boolean   @default(false)
  audienceRole String?
  expiresAt   DateTime?
  authorId    String
  author      User      @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pinned, expiresAt])
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("INVESTIGATING")
  severity    String   @default("MINOR")
  reporterId  String
  reporter    User     @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?    @relation("IncidentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  linkedIssues IncidentIssue[]

  @@index([status])
}

model IncidentIssue {
  id         String   @id @default(cuid())
  incidentId String
  issueId    String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([incidentId, issueId])
}

model Release {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("PLANNED")
  targetDate  DateTime?
  authorId    String
  author      User     @relation("ReleaseAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  issues      ReleaseIssue[]

  @@index([status])
}

model ReleaseIssue {
  id        String   @id @default(cuid())
  releaseId String
  issueId   String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([releaseId, issueId])
}

model PlayerReport {
  id               String   @id @default(cuid())
  title            String
  description      String?
  reporterName     String?
  accusedPlayer    String?
  // Discord identity of the member this mod-log entry is about.
  subjectDiscordId String?
  subjectName      String?
  category         String   @default("OTHER")
  evidenceLinks    String?
  status           String   @default("OPEN")
  reporterId       String
  reporter         User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assigneeId       String?
  assignee         User?    @relation("ReportAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  linkedIssues     PlayerReportIssue[]

  @@index([status])
  @@index([subjectDiscordId])
}

model PlayerReportIssue {
  id       String       @id @default(cuid())
  reportId String
  issueId  String
  report   PlayerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  issue    Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([reportId, issueId])
}
